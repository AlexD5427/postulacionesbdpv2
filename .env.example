# =============================================================================
# BDP — Portal público de candidatos
# Variables de entorno de ejemplo. Copia este archivo a `.env.local`.
# NUNCA subas secretos reales al repositorio.
# =============================================================================

# --- Identidad de la aplicación --------------------------------------------
NEXT_PUBLIC_APP_NAME="Banco de Desarrollo Productivo BDP S.A.M."
NEXT_PUBLIC_APP_ENV=development

# --- Modo de datos ----------------------------------------------------------
# Valores permitidos: mock | supabase | apps-script | hybrid
NEXT_PUBLIC_DATA_MODE=mock
NEXT_PUBLIC_ENABLE_MOCKS=true

# --- Feature flags (cliente) ------------------------------------------------
NEXT_PUBLIC_ENABLE_WEBGL=false
NEXT_PUBLIC_ENABLE_AMBIENT_VIDEO=true
NEXT_PUBLIC_ENABLE_ASSESSMENTS=true
NEXT_PUBLIC_ENABLE_ASSESSMENT_TELEMETRY=true
NEXT_PUBLIC_ENABLE_COVER_LETTERS=true
NEXT_PUBLIC_ENABLE_GOOGLE_APPS_SCRIPT=false
NEXT_PUBLIC_ENABLE_SUPABASE=false
NEXT_PUBLIC_ENABLE_ARCHIVE_API=false
NEXT_PUBLIC_ENABLE_AI_ASSIST=false

# --- Endpoints públicos (seguros para el navegador) -------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_APPS_SCRIPT_PUBLIC_READ_URL=
NEXT_PUBLIC_ARCHIVE_API_URL=

# =============================================================================
# SECRETOS SOLO DEL SERVIDOR — NUNCA usar el prefijo NEXT_PUBLIC_
# El navegador jamás debe requerir estos valores. Se usan en rutas/route
# handlers y server actions (backend-for-frontend). Ver SECURITY.md.
# =============================================================================
SUPABASE_SERVICE_ROLE_KEY=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
APPS_SCRIPT_SERVER_SECRET=
ARCHIVE_API_SERVER_TOKEN=
